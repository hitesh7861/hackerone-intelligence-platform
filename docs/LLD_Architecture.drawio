        <mxCell id="elt-component" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="ELT Pipeline&#xa;&#xa;1. Extract (extract.py)&#xa;   → Load CSV from HuggingFace&#xa;   → Parse nested JSON&#xa;   → Data validation&#xa;&#xa;2. Load (load.py)&#xa;   → Create raw_reports table&#xa;   → Bulk insert data&#xa;&#xa;3. Transform (transform.py)&#xa;   → Build dimensions&#xa;   → Create fact table&#xa;   → Generate views" vertex="1">
          <mxGeometry height="200" width="210" x="40" y="780" as="geometry" />
        </mxCell>
        <mxCell id="api-component" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="FastAPI Application&#xa;&#xa;• JWT Authentication&#xa;  → Token generation&#xa;  → Token validation&#xa;  → Role-based access&#xa;&#xa;• Route Handlers&#xa;  → Request validation&#xa;  → Business logic&#xa;  → Response formatting&#xa;&#xa;• Database Connection&#xa;  → Connection pooling&#xa;  → Query execution&#xa;  → Result mapping" vertex="1">
          <mxGeometry height="200" width="210" x="270" y="780" as="geometry" />
        </mxCell>
        <mxCell id="ai-component" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="AI NLP Engine&#xa;&#xa;• Query Classification&#xa;  → Keyword detection&#xa;  → Intent recognition&#xa;  → Mode selection&#xa;&#xa;• SQL Generation&#xa;  → Schema context&#xa;  → Query construction&#xa;  → Validation&#xa;&#xa;• Response Formatting&#xa;  → Data presentation&#xa;  → Explanation generation" vertex="1">
          <mxGeometry height="200" width="210" x="500" y="781" as="geometry" />
        </mxCell>
        <mxCell id="dashboard-component" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="Streamlit Dashboard&#xa;&#xa;• Page Routing&#xa;  → Navigation system&#xa;  → Page rendering&#xa;&#xa;• Data Visualization&#xa;  → Plotly charts&#xa;  → Interactive filters&#xa;  → Real-time updates&#xa;&#xa;• Direct DB Access&#xa;  → No API dependency&#xa;  → View queries&#xa;  → Data caching" vertex="1">
          <mxGeometry height="190" width="210" x="40" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="security-component" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="Security Layer&#xa;&#xa;• JWT Authentication&#xa;  → HS256 algorithm&#xa;  → 30-minute expiry&#xa;  → Secure secret key&#xa;&#xa;• RBAC Implementation&#xa;  → Admin: Full access&#xa;  → Customer: Own data only&#xa;  → Decorator-based checks&#xa;&#xa;• Data Isolation&#xa;  → Query filtering&#xa;  → Organization-based" vertex="1">
          <mxGeometry height="190" width="210" x="270" y="1000" as="geometry" />
        </mxCell>
